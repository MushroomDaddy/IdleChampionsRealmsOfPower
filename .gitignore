# Unity .gitignore
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore

# Unity generated files
Library/
Temp/
Obj/
Build/
Builds/
# Keep ProjectSettings files for proper Unity project recognition
# ProjectSettings/ProjectVersion.txt
# ProjectSettings/EditorBuildSettings.asset
# ProjectSettings/ProjectSettings.asset

# Visual Studio cache directory
.vs/

# Autogenerated VS/MD/Consulo solution and project files
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated files
*.apk
*.aab
*.unitypackage
*.app
*.xcodeproj
*.xcworkspace

# Crashlytics plugin generated files
crashlytics-build.properties

# Personal settings for Visual Studio
.idea/.idea.UnityEngine.xml

# Android
android/
android/.gradle/
android/app/build/
android/build/
android/gradle/
android/gradlew
android/gradle.bat
android/local.properties

# iOS
ios/
ios/Pods/
ios/Podfile.lock

# Windows Store
AppPackages/
BundleArtifacts/
Package.appxmanifest

# WebGL
Builds/WebGL/

# LSP (Language Server Protocol) logs
lsp.log
lsp/

# Node.js (if using Node for tools)
node_modules/
package-lock.json
npm-debug.log
yarn-error.log

# OS metadata files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# User-specific files
*.userprefs
*.usertemp
*.prefab.cs

# Audio extracted from APK (optional - large files)
apk_full_analysis/

# Python (for Hermes tools)
__pycache__/
*.pyc
*.pyo
.env
venv/
